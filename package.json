  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "yarn server:dev & yarn next:dev",
    "build": "yarn install && yarn next:build",
    "start": "yarn server:prod & yarn next:start",
    "next:dev": "next dev --turbopack",
    "next:build": "next build",
    "next:start": "next start",
    "server:dev": "set NODE_ENV=development && node ./server/main.ts",
    "server:prod": "set NODE_ENV=production && node ./server/main.ts",
    "prisma:generate": "yarn prisma generate",
    "prisma:migrate": "yarn prisma migrate dev --name init",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.7",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "prisma": "^6.2.1",
    "sass": "^1.83.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.7.3"
  }
}
