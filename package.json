  "private": true,
  "scripts": {
    "dev": "concurrently \"yarn server-start\" \"yarn next-dev\"",
    "build": "yarn install --force && yarn next-build",
    "start": "concurrently \"yarn server-start\" \"yarn next-start\"",
    "next-dev": "next dev --turbopack",
    "next-build": "next build",
    "next-start": "next start",
    "lint": "next lint",
    "server-start": "node ./server/main.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "concurrently": "^9.1.2",
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.7",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "prisma": "^6.2.1",
    "sass": "^1.83.4",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
