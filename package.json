{
  "name": "riksdagen",
  "version": "0.1.0",
  "repository": "https://github.com/Server-Departementet/Riksdagen.git",
  "author": "viggoStrom <viggostrom05@gmail.com> axelNTI <taxel.test@gmail.com> Winroth13 <emil.winroth@gmail.com>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "yarn concurrently \"yarn server:dev\" \"yarn next:dev\"",
    "build": "yarn install && yarn next:build && yarn server:build",
    "start": "yarn concurrently \"yarn server:start\" \"yarn next:start\"",
    "next:dev": "next dev --turbopack",
    "next:build": "next build",
    "next:start": "next start",
    "server:dev:watch": "set NODE_ENV=development && yarn ts-node-dev ./server/main.ts",
    "server:dev": "set NODE_ENV=development && yarn tsc ./server/main.ts && node ./server/main.js",
    "server:build": "set NODE_ENV=production && yarn tsc ./server/main.ts && node ./server/main.js",
    "server:start": "set NODE_ENV=production && node ./server/main.js",
    "prisma:push": "yarn prisma migrate dev --name init",
    "prisma:reset": "yarn prisma migrate reset --force && yarn prisma:push",
    "lint": "next lint"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "concurrently": "^9.1.2",
    "discord.js": "^14.17.3",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "prisma": "^6.2.1",
    "sass": "^1.83.4",
    "tailwindcss": "^3.4.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
